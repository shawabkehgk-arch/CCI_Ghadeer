        "# Step C: Match patient medications against interaction table\n",
        "interaction_alerts = []\n",
        "\n",
        "for patient in patients:\n",
        "    meds = set(patient.medications)\n",
        "    for _, row in interactions.iterrows():\n",
        "        if row[\"drug1\"] in meds and row[\"drug2\"] in meds:\n",
        "            interaction_alerts.append({\n",
        "                \"name\": patient.name,\n",
        "                \"mrn\": patient.mrn,\n",
        "                \"diagnosis\": patient.diagnosis,\n",
        "                \"drug1\": row[\"drug1\"],\n",
        "                \"drug2\": row[\"drug2\"],\n",
        "                \"interaction_severity\": row[\"interaction_severity\"],\n",
        "                \"description\": row[\"description\"]\n",
        "            })\n",
        "\n",
        "drug_alerts_df = pd.DataFrame(interaction_alerts)\n",
        "\n",
        "print(\"Drug interaction alerts:\")\n",
        "print(drug_alerts_df if not drug_alerts_df.empty else \"No interactions found\")"
